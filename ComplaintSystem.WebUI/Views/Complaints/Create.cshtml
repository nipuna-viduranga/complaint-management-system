@model ComplaintSystem.Application.DTOs.CreateComplaintDto
@{
    ViewData["Title"] = "File a Complaint";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card p-5">
            <h2 class="fw-bold mb-4">File a New Complaint</h2>
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-semibold">Short Title</label>
                    <input asp-for="Title" class="form-control form-control-lg border-0 shadow-sm" placeholder="e.g. WiFi not working in lobby" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select form-select-lg border-0 shadow-sm"
                            asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">Detailed Description</label>
                    <textarea asp-for="Description" class="form-control border-0 shadow-sm" rows="5" placeholder="Please provide as much detail as possible..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2 mt-5">
                    <button type="submit" class="btn btn-primary btn-lg">Submit Complaint</button>
                    <a asp-action="Index" class="btn btn-link text-secondary">Back to My Complaints</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
