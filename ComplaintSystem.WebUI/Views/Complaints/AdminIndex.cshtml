@using ComplaintSystem.Domain.Enums
@model IEnumerable<ComplaintSystem.Application.DTOs.ComplaintDto>
@{
    ViewData["Title"] = "Complaint Management";
    var currentStatus = ViewBag.CurrentStatus as ComplaintStatus?;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Complaint Management</h2>
        
        <div class="dropdown">
            <button class="btn btn-glass dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Filter: @(currentStatus?.ToString() ?? "All Tasks")
            </button>
            <ul class="dropdown-menu border-0 shadow-lg">
                <li><a class="dropdown-item" asp-action="AdminIndex" asp-route-status="">All Tasks</a></li>
                @foreach (var status in Enum.GetValues(typeof(ComplaintStatus)))
                {
                    <li><a class="dropdown-item" asp-action="AdminIndex" asp-route-status="@status">@status</a></li>
                }
            </ul>
        </div>
    </div>

    <div class="glass-card overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="bg-primary bg-opacity-10">
                <tr>
                    <th class="ps-4">Title</th>
                    <th>Requester</th>
                    <th>Category</th>
                    <th>Dept</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var complaint in Model)
                {
                    <tr>
                        <td class="ps-4 py-3">
                            <span class="fw-semibold d-block">@complaint.Title</span>
                            <small class="text-muted">@complaint.CreatedAt.ToShortDateString()</small>
                        </td>
                        <td>@complaint.UserId.Substring(0, 8)...</td>
                        <td>@complaint.CategoryName</td>
                        <td>@complaint.DepartmentName</td>
                        <td>
                            <span class="status-badge status-@complaint.Status.ToString().ToLower()">
                                @complaint.Status
                            </span>
                        </td>
                        <td>
                           <span class="badge border text-dark priority-@complaint.Priority.ToString().ToLower()">@complaint.Priority</span>
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Details" asp-route-id="@complaint.Id" class="btn btn-sm btn-primary">Process</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center p-5">
                <p class="text-muted">No complaints found matching this criteria.</p>
            </div>
        }
    </div>
</div>

<style>
    .btn-glass {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 0.5rem;
    }
    .badge.priority-critical { background: #fee2e2; color: #991b1b; }
    .badge.priority-high { background: #ffedd5; color: #9a3412; }
    .badge.priority-medium { background: #fef9c3; color: #854d0e; }
    .badge.priority-low { background: #dcfce7; color: #166534; }
</style>
