@model IEnumerable<ComplaintSystem.Application.DTOs.ComplaintDto>
@{
    ViewData["Title"] = "My Complaints";
}

<div class="animate-fade-in container">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-5 text-white mb-0">My <span style="color:var(--primary)">Complaints</span></h1>
            <p class="text-secondary mb-0">Track and manage your filed reports.</p>
        </div>
        <a asp-action="Create" class="btn-modern btn-modern-primary text-decoration-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
            </svg>
            File New Complaint
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card p-5 text-center my-5">
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="var(--text-muted)" class="bi bi-folder2-open" viewBox="0 0 16 16">
                  <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h2.764c.312 0 .611.115.842.322L7.392 3.5H12.5A1.5 1.5 0 0 1 14 5v8.5a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 13.5v-10zM2.5 3a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h11a.5.5 0 0 0 .5-.5V5a.5.5 0 0 0-.5-.5H7.008a.5.5 0 0 1-.299-.1l-1.332-1.033A.5.5 0 0 0 5.264 3H2.5z"/>
                </svg>
            </div>
            <h3 class="text-white h4">No complaints found</h3>
            <p class="text-secondary mb-4">You haven't filed any complaints yet. We're here to help when you do.</p>
            <a asp-action="Create" class="btn-modern btn-modern-glass text-decoration-none">Start Resolution</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var complaint in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="glass-card h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="badge-modern badge-@complaint.Status.ToString().ToLower()">
                                @complaint.Status
                            </span>
                            <small class="text-muted">@complaint.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        
                        <h3 class="h5 text-white mb-3">@complaint.Title</h3>
                        <p class="text-secondary small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @complaint.Description
                        </p>
                        
                        <div class="mt-4 pt-4 border-top border-glass">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="small text-muted mb-0">Category</p>
                                    <p class="small text-white fw-bold mb-0">@complaint.CategoryName</p>
                                </div>
                                <a asp-action="Details" asp-route-id="@complaint.Id" class="btn-modern btn-modern-glass btn-sm text-decoration-none">
                                    Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
