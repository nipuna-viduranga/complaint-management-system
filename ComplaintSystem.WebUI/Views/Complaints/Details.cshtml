@using ComplaintSystem.Domain.Enums
@model ComplaintSystem.Application.DTOs.ComplaintDto
@{
    ViewData["Title"] = "Complaint Details";
    var comments = ViewBag.Comments as IEnumerable<ComplaintSystem.Application.DTOs.CommentDto>;
    var logs = ViewBag.Logs as IEnumerable<ComplaintSystem.Domain.Entities.ComplaintLog>;
}

<div class="animate-fade-in container pb-5">
    <div class="d-flex align-items-center gap-3 mb-5">
        <a asp-action="Index" class="btn-modern btn-modern-glass btn-sm text-decoration-none py-2 px-3">
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
            </svg>
            Back
        </a>
        <h1 class="h3 text-white mb-0">Complaint <span class="text-secondary">#@Model.Id.ToString().Substring(0,8)</span></h1>
    </div>

    <div class="row g-4">
        <!-- Left Column: Primary Details & Conversation -->
        <div class="col-lg-8">
            <div class="glass-card mb-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <span class="badge-modern badge-@Model.Status.ToString().ToLower() mb-3 d-inline-block">@Model.Status</span>
                        <h2 class="h3 text-white">@Model.Title</h2>
                    </div>
                    <div class="text-end text-muted small">
                        <p class="mb-0">Created: @Model.CreatedAt.ToString("MMM dd, yyyy")</p>
                        <p class="mb-0">Last Active: @(logs?.OrderByDescending(l => l.CreatedAt).FirstOrDefault()?.CreatedAt.ToString("HH:mm") ?? "N/A")</p>
                    </div>
                </div>

                <div class="mb-4">
                    <p class="text-secondary fs-5" style="line-height: 1.6;">@Model.Description</p>
                </div>

                <div class="row g-3 pt-4 border-top border-glass">
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Category</small>
                        <span class="text-white">@Model.CategoryName</span>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Priority</small>
                        <span class="text-white">@Model.Priority</span>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Department</small>
                        <span class="text-white">@(Model.DepartmentName ?? "Unassigned")</span>
                    </div>
                </div>
            </div>

            <!-- Conversation Section -->
            <div class="glass-card">
                <h3 class="h5 text-white mb-4">Conversation</h3>
                
                <div class="pe-2" style="max-height: 500px; overflow-y: auto;">
                    @if (comments != null && comments.Any())
                    {
                        foreach (var comment in comments)
                        {
                            <div class="mb-4 animate-fade-in p-3 rounded-4 @(comment.IsInternalOnly ? "bg-warning bg-opacity-10 border border-warning border-opacity-25" : "bg-white bg-opacity-5")">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white small fw-bold" style="width:24px;height:24px; font-size:10px;">@comment.UserName.Substring(0,1).ToUpper()</div>
                                        <span class="fw-bold text-white small">@comment.UserName</span>
                                    </div>
                                    <small class="text-muted">@comment.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                </div>
                                <p class="mb-0 text-secondary small">@comment.Content</p>
                                @if (comment.IsInternalOnly)
                                {
                                    <div class="mt-2"><span class="badge bg-warning text-dark x-small">INTERNAL STAFF ONLY</span></div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <p class="text-muted italic small mb-0">No messages in this thread yet.</p>
                        </div>
                    }
                </div>

                <div class="mt-4 pt-4 border-top border-glass">
                    <form asp-action="AddComment" method="post">
                        <input type="hidden" name="ComplaintId" value="@Model.Id" />
                        <div class="mb-3">
                            <textarea name="Content" class="form-input-modern" rows="3" placeholder="Type your message here..." required></textarea>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center">
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" name="IsInternalOnly" value="true" id="internalCheck">
                                    <label class="form-check-label text-muted small" for="internalCheck">Internal Only</label>
                                </div>
                            }
                            else { <div></div> }
                            <button type="submit" class="btn-modern btn-modern-primary btn-sm">
                                Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Status & Timeline -->
        <div class="col-lg-4">
            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <div class="glass-card mb-4 border border-primary border-opacity-25">
                    <h5 class="text-white mb-4 h6 text-uppercase letter-spacing-1">Management Actions</h5>
                    
                    <form asp-action="UpdateStatus" method="post" class="mb-4">
                        <input type="hidden" name="Id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="small text-muted mb-2">Change Status</label>
                            <select name="Status" class="form-input-modern text-white">
                                @foreach (var status in Enum.GetValues(typeof(ComplaintStatus)))
                                {
                                    <!option value="@status" @(Model.Status.Equals(status) ? "selected" : "")>@status</!option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted mb-2">Update Priority</label>
                            <select name="Priority" class="form-input-modern text-white">
                                @foreach (var priority in Enum.GetValues(typeof(Priority)))
                                {
                                    <!option value="@priority" @(Model.Priority.Equals(priority) ? "selected" : "")>@priority</!option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn-modern btn-modern-primary w-100 justify-content-center">Save Changes</button>
                    </form>

                    <form asp-action="AssignDepartment" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="small text-muted mb-2">Assign to Department</label>
                        <select name="departmentId" class="form-input-modern text-white mb-3">
                            <option value="">-- Select Department --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in (IEnumerable<ComplaintSystem.Domain.Entities.Department>)ViewBag.Departments)
                                {
                                    <!option value="@dept.Id" @(Model.DepartmentId == dept.Id ? "selected" : "")>@dept.Name</!option>
                                }
                            }
                        </select>
                        <button type="submit" class="btn-modern btn-modern-glass w-100 justify-content-center">Assign Dept</button>
                    </form>
                </div>
            }

            <div class="glass-card">
                <h5 class="text-white mb-4 h6 text-uppercase letter-spacing-1">Status Timeline</h5>
                <div class="timeline ps-1">
                    @if (logs != null)
                    {
                        foreach (var log in logs.OrderByDescending(l => l.CreatedAt))
                        {
                            <div class="timeline-item pb-4 border-start border-glass ps-4 position-relative">
                                <div class="position-absolute translate-middle-x bg-primary rounded-circle" style="left:0; top:5px; width:12px; height:12px; box-shadow: 0 0 10px var(--primary)"></div>
                                <div class="animate-fade-in">
                                    <small class="text-muted d-block mb-1">@log.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                    <p class="mb-0 text-white small fw-bold">@log.ActionDetails</p>
                                    @if (log.OldStatus.HasValue && log.NewStatus.HasValue)
                                    {
                                        <div class="mt-2 d-flex align-items-center gap-2">
                                            <span class="text-muted x-small">@log.OldStatus</span>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="gray" viewBox="0 0 16 16"><path d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/></svg>
                                            <span class="text-primary x-small fw-bold">@log.NewStatus</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
