<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Digital Complaint System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ComplaintSystem.WebUI.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar-modern mb-4">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="brand-font fs-4 text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index" style="color:var(--text-primary)">
                    <span style="color:var(--primary)">Digital</span>Complaint
                </a>
                
                <div class="d-flex align-items-center gap-3">
                    <div class="d-none d-md-flex gap-2">
                        <a class="nav-link-modern @(Context.Request.Path.Value == "/" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        <a class="nav-link-modern @(Context.Request.Path.StartsWithSegments("/Complaints") && !Context.Request.Path.Value.Contains("AdminIndex") ? "active" : "")" asp-area="" asp-controller="Complaints" asp-action="Index">My Complaints</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <a class="nav-link-modern @(Context.Request.Path.Value.Contains("AdminIndex") ? "active" : "")" asp-area="" asp-controller="Complaints" asp-action="AdminIndex">Management</a>
                            <a class="nav-link-modern @(Context.Request.Path.StartsWithSegments("/Dashboard") ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">Analytics</a>
                        }
                    </div>
                    <div class="ms-3 border-start ps-3 border-glass">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-5">
        <main role="main" class="animate-fade-in">
            @RenderBody()
        </main>
    </div>

    <!-- Notification Toast -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
      <div id="notificationToast" class="toast hide glass-card border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header bg-transparent border-0">
          <div class="me-2 rounded-circle" style="width:10px;height:10px;background:var(--primary)"></div>
          <strong class="me-auto">Notification</strong>
          <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="notificationMessage"></div>
      </div>
    </div>

    <footer class="footer mt-auto py-2 border-top border-glass bg-white bg-opacity-70">
        <div class="container text-center">
            <p class="mb-0 small text-secondary">
                &copy; 2026 powered by <span class="fw-bold" style="color:var(--primary)">Creativedesigns</span> - Nipuna Viduranga
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveNotification", function (message) {
            const toastElement = document.getElementById('notificationToast');
            document.getElementById('notificationMessage').innerText = message;
            const toast = new bootstrap.Toast(toastElement);
            toast.show();
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
