@using Microsoft.AspNetCore.Identity
@using ComplaintSystem.Infrastructure.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    <a id="manage" class="nav-link-modern" asp-area="Identity" asp-page="/Account/Manage/Index" title="Settings">
        <span class="d-flex align-items-center gap-2">
            <div class="rounded-circle bg-primary bg-opacity-20 d-flex align-items-center justify-content-center text-primary" style="width:32px;height:32px;font-size:12px;font-weight:700">
                @((await UserManager.GetUserAsync(User))?.FullName?.Substring(0,1).ToUpper() ?? "U")
            </div>
            <span class="d-none d-lg-inline">Account</span>
        </span>
    </a>
    <form id="logoutForm" class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button id="logout" type="submit" class="btn-modern btn-modern-glass btn-sm border-0">Sign Out</button>
    </form>
}
else
{
    <a class="nav-link-modern" id="login" asp-area="Identity" asp-page="/Account/Login">Sign In</a>
    <a class="btn-modern btn-modern-primary btn-sm text-decoration-none" id="register" asp-area="Identity" asp-page="/Account/Register">Get Started</a>
}
</div>
