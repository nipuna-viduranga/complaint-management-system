@page
@model LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-bg-decor">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
</div>

<div class="auth-container">
    <div class="auth-card glass-card animate-fade-in">
        <div class="auth-header">
            <h1 class="brand-font">Welcome Back</h1>
            <p>Please sign in to your account.</p>
        </div>

        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email Address</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="checkbox mb-3 d-flex justify-content-between align-items-center">
                    <label asp-for="Input.RememberMe" class="form-label mb-0">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn-modern btn-modern-primary py-3">
                    Sign In
                </button>

                <div class="auth-footer-links">
                    <p class="mb-0 text-muted">Don't have an account?</p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                </div>

                <div class="mt-3 text-center">
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="small text-muted text-decoration-none">Resend email confirmation</a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
