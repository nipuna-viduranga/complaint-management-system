## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
*.user
*.suo

# SQLite
*.db
*.db-shm
*.db-wal

# User-specific files
*.user
*.userosscache
*.sln.docstates

# Packages
*.nupkg
**/packages/*
!**/packages/build/

# IDE files
.vscode/

# OS generated files
.DS_Store
Thumbs.db
